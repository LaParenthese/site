// Configuration Cloudflare Workers (déploiement "static assets").
// Utilisée uniquement si le site est déployé via un Worker ;
// le flux Pages classique n'en a pas besoin.
{
  "name": "laparenthese-samois",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./public",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  }
}
